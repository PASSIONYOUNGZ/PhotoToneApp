<Window x:Class="PhotoToneApp.Windows.ImageCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PhotoToneApp.Controls"
        Title="双图对比"
        Width="1400"
        Height="850"
        MinWidth="980"
        MinHeight="620"
        Background="#111827"
        PreviewKeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1F2937"
                BorderBrush="#374151"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <CheckBox x:Name="SyncViewCheckBox"
                              Content="同步视图"
                              IsChecked="True"
                              Foreground="#F9FAFB"
                              VerticalAlignment="Center"
                              Margin="0,0,14,0" />
                    <TextBlock x:Name="ActiveSideTextBlock"
                               Text="当前：左图"
                               Foreground="#F9FAFB"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0" />
                    <Button Content="左图上一张" Width="86" Height="30" Margin="0,0,8,0" Click="LeftPreviousButton_Click" />
                    <Button Content="左图下一张" Width="86" Height="30" Margin="0,0,8,0" Click="LeftNextButton_Click" />
                    <Button Content="右图上一张" Width="86" Height="30" Margin="0,0,8,0" Click="RightPreviousButton_Click" />
                    <Button Content="右图下一张" Width="86" Height="30" Margin="0,0,8,0" Click="RightNextButton_Click" />
                    <Button Content="适应窗口" Width="86" Height="30" Margin="0,0,8,0" Click="FitBothButton_Click" />
                    <Button Content="100%" Width="64" Height="30" Margin="0,0,8,0" Click="ActualSizeBothButton_Click" />
                    <Button x:Name="FavoriteLeftButton" Content="收藏左图" Width="86" Height="30" Margin="0,0,8,0" Click="FavoriteLeftButton_Click" />
                    <Button x:Name="FavoriteRightButton" Content="收藏右图" Width="86" Height="30" Margin="0,0,8,0" Click="FavoriteRightButton_Click" />
                    <Button Content="关闭" Width="72" Height="30" Click="CloseButton_Click" />
                </WrapPanel>

                <TextBlock Text="1-5 评分，0 清除，P 入选，X 淘汰，F 收藏，A/D 左图，J/L 右图，S 同步，Esc 关闭"
                           Foreground="#D1D5DB"
                           VerticalAlignment="Center"
                           TextAlignment="Right"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Background="#111827">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" PreviewMouseDown="LeftSide_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#111827" Padding="10">
                    <StackPanel>
                        <ComboBox x:Name="LeftImageComboBox"
                                  Height="28"
                                  Margin="0,0,0,8"
                                  SelectionChanged="LeftImageComboBox_SelectionChanged" />
                        <TextBlock x:Name="LeftFileNameTextBlock"
                                   Foreground="#F9FAFB"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="LeftInfoTextBlock"
                                   Foreground="#D1D5DB"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis" />
                        <WrapPanel Margin="0,8,0,0">
                            <ComboBox x:Name="LeftRatingComboBox"
                                      Width="92"
                                      Height="28"
                                      Margin="0,0,8,0"
                                      SelectionChanged="LeftRatingComboBox_SelectionChanged" />
                            <Button x:Name="LeftPickButton"
                                    Content="入选"
                                    Width="76"
                                    Height="28"
                                    Margin="0,0,8,0"
                                    Click="LeftPickButton_Click" />
                            <Button x:Name="LeftRejectButton"
                                    Content="淘汰"
                                    Width="76"
                                    Height="28"
                                    Click="LeftRejectButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <controls:ZoomableImageViewer x:Name="LeftViewer" />
                    <TextBlock x:Name="LeftMessageTextBlock"
                               Text="图片加载失败"
                               Foreground="#E5E7EB"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               IsHitTestVisible="False" />
                </Grid>
            </Grid>

            <Border Grid.Column="1" Background="#374151" />

            <Grid Grid.Column="2" PreviewMouseDown="RightSide_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#111827" Padding="10">
                    <StackPanel>
                        <ComboBox x:Name="RightImageComboBox"
                                  Height="28"
                                  Margin="0,0,0,8"
                                  SelectionChanged="RightImageComboBox_SelectionChanged" />
                        <TextBlock x:Name="RightFileNameTextBlock"
                                   Foreground="#F9FAFB"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="RightInfoTextBlock"
                                   Foreground="#D1D5DB"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis" />
                        <WrapPanel Margin="0,8,0,0">
                            <ComboBox x:Name="RightRatingComboBox"
                                      Width="92"
                                      Height="28"
                                      Margin="0,0,8,0"
                                      SelectionChanged="RightRatingComboBox_SelectionChanged" />
                            <Button x:Name="RightPickButton"
                                    Content="入选"
                                    Width="76"
                                    Height="28"
                                    Margin="0,0,8,0"
                                    Click="RightPickButton_Click" />
                            <Button x:Name="RightRejectButton"
                                    Content="淘汰"
                                    Width="76"
                                    Height="28"
                                    Click="RightRejectButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <controls:ZoomableImageViewer x:Name="RightViewer" />
                    <TextBlock x:Name="RightMessageTextBlock"
                               Text="图片加载失败"
                               Foreground="#E5E7EB"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               IsHitTestVisible="False" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
