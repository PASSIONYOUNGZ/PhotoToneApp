<Window x:Class="PhotoToneApp.Windows.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PhotoToneApp.Controls"
        Title="图片查看"
        Width="1200"
        Height="800"
        MinWidth="820"
        MinHeight="540"
        Background="#111827"
        PreviewKeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1F2937"
                BorderBrush="#374151"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Left">
                    <Button x:Name="PreviousButton" Content="上一张" Width="72" Height="30" Margin="0,0,8,0" Click="PreviousButton_Click" />
                    <Button x:Name="NextButton" Content="下一张" Width="72" Height="30" Margin="0,0,8,0" Click="NextButton_Click" />
                    <Button Content="适应窗口" Width="86" Height="30" Margin="0,0,8,0" Click="FitButton_Click" />
                    <Button Content="100%" Width="64" Height="30" Margin="0,0,8,0" Click="ActualSizeButton_Click" />
                    <Button x:Name="FullScreenButton" Content="全屏" Width="72" Height="30" Margin="0,0,8,0" Click="FullScreenButton_Click" />
                    <Button Content="1星" Width="48" Height="30" Margin="0,0,8,0" Tag="1" Click="RatingButton_Click" />
                    <Button Content="2星" Width="48" Height="30" Margin="0,0,8,0" Tag="2" Click="RatingButton_Click" />
                    <Button Content="3星" Width="48" Height="30" Margin="0,0,8,0" Tag="3" Click="RatingButton_Click" />
                    <Button Content="4星" Width="48" Height="30" Margin="0,0,8,0" Tag="4" Click="RatingButton_Click" />
                    <Button Content="5星" Width="48" Height="30" Margin="0,0,8,0" Tag="5" Click="RatingButton_Click" />
                    <Button Content="清除评分" Width="82" Height="30" Margin="0,0,8,0" Click="ClearRatingButton_Click" />
                    <Button x:Name="ViewerFavoriteButton" Content="收藏" Width="72" Height="30" Margin="0,0,8,0" Click="FavoriteButton_Click" />
                    <Button x:Name="ViewerPickButton" Content="入选" Width="72" Height="30" Margin="0,0,8,0" Click="PickButton_Click" />
                    <Button x:Name="ViewerRejectButton" Content="淘汰" Width="72" Height="30" Margin="0,0,8,0" Click="RejectButton_Click" />
                    <Button Content="关闭" Width="72" Height="30" Click="CloseButton_Click" />
                </WrapPanel>

                <TextBlock x:Name="HeaderInfoTextBlock"
                           Foreground="#E5E7EB"
                           VerticalAlignment="Center"
                           TextAlignment="Right"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Background="#111827">
            <controls:ZoomableImageViewer x:Name="ImageViewer" />
            <TextBlock x:Name="ViewerMessageTextBlock"
                       Text="图片加载失败"
                       Foreground="#E5E7EB"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"
                       IsHitTestVisible="False" />
        </Grid>

        <Border Grid.Row="2"
                Background="#1F2937"
                BorderBrush="#374151"
                BorderThickness="0,1,0,0"
                Padding="10,0">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="FileNameTextBlock"
                           DockPanel.Dock="Left"
                           Width="330"
                           Foreground="#F9FAFB"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="IndexTextBlock" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock x:Name="DimensionsTextBlock" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock x:Name="ToneTextBlock" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock x:Name="FavoriteTextBlock" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock x:Name="RatingTextBlock" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock x:Name="PickStateTextBlock" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock x:Name="RejectStateTextBlock" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock x:Name="ZoomTextBlock" Foreground="#D1D5DB" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
